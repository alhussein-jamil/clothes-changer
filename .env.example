# Runtime / deployment — see config/content*.yaml for prompts, models, and generation defaults.

CLOTHES_CHANGER_HOST=0.0.0.0
CLOTHES_CHANGER_PORT=7860
CLOTHES_CHANGER_DEBUG=false
# DEBUG | INFO | WARNING | ERROR | CRITICAL  (CLOTHES_CHANGER_DEBUG=true forces DEBUG)
CLOTHES_CHANGER_LOG_LEVEL=INFO

CLOTHES_CHANGER_MODELS_DIR=models
CLOTHES_CHANGER_OUTPUT_DIR=outputs
CLOTHES_CHANGER_DB_PATH=database.db
CLOTHES_CHANGER_MAX_IMAGE_SIZE=1024

CLOTHES_CHANGER_DEFAULT_ADMIN=admin
CLOTHES_CHANGER_DEFAULT_PASSWORD=admin
CLOTHES_CHANGER_DEFAULT_CREDITS=100
# Set to false to skip the login page (uses default admin session)
CLOTHES_CHANGER_REQUIRE_AUTH=true

# Save per-step pipeline images + run_metadata.json (default dir: debug-pipeline/)
CLOTHES_CHANGER_PIPELINE_DEBUG=false
# CLOTHES_CHANGER_PIPELINE_DEBUG_DIR=debug-pipeline
