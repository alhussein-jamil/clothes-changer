# Runtime / deployment — see config/content*.yaml for prompts, models, and generation defaults.

OUTFIT_STUDIO_HOST=0.0.0.0
OUTFIT_STUDIO_PORT=7860
OUTFIT_STUDIO_DEBUG=false
# DEBUG | INFO | WARNING | ERROR | CRITICAL  (OUTFIT_STUDIO_DEBUG=true forces DEBUG)
OUTFIT_STUDIO_LOG_LEVEL=INFO

OUTFIT_STUDIO_MODELS_DIR=models
OUTFIT_STUDIO_OUTPUT_DIR=outputs
OUTFIT_STUDIO_DB_PATH=database.db
OUTFIT_STUDIO_MAX_IMAGE_SIZE=1024

# --- Authentication (required for production) ---
# Generate for production: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Local dev (localhost): auto-generated if left as placeholder below
OUTFIT_STUDIO_SESSION_SECRET=change-me-in-production
# Public URL users visit (for deployment behind reverse proxy)
OUTFIT_STUDIO_PUBLIC_BASE_URL=http://localhost:7860
# Set true behind HTTPS reverse proxy (nginx, Caddy, etc.)
OUTFIT_STUDIO_SESSION_COOKIE_SECURE=false
OUTFIT_STUDIO_REQUIRE_AUTH=true
OUTFIT_STUDIO_ALLOW_LOCAL_SIGNUP=true
OUTFIT_STUDIO_ALLOW_BOOTSTRAP_ADMIN=true
OUTFIT_STUDIO_ENFORCE_SINGLE_ACCOUNT_PER_IP=true
OUTFIT_STUDIO_ENFORCE_SINGLE_ACCOUNT_PER_DEVICE=true

# Rate limits (per IP)
OUTFIT_STUDIO_LOGIN_RATE_LIMIT=10
OUTFIT_STUDIO_LOGIN_RATE_WINDOW_S=300
OUTFIT_STUDIO_SIGNUP_RATE_LIMIT=5
OUTFIT_STUDIO_SIGNUP_RATE_WINDOW_S=3600

# Behind reverse proxy — trust X-Forwarded-For from these IPs (comma-separated)
OUTFIT_STUDIO_FORWARDED_ALLOW_IPS=127.0.0.1
OUTFIT_STUDIO_TRUSTED_PROXY_HOPS=1

# Bootstrap admin (created only if missing on first start)
OUTFIT_STUDIO_DEFAULT_ADMIN=admin
OUTFIT_STUDIO_DEFAULT_PASSWORD=admin1234
OUTFIT_STUDIO_DEFAULT_CREDITS=100

# Save per-step pipeline images + run_metadata.json (default dir: debug-pipeline/)
OUTFIT_STUDIO_PIPELINE_DEBUG=false
# OUTFIT_STUDIO_PIPELINE_DEBUG_DIR=debug-pipeline
# OUTFIT_STUDIO_LOGO_PATH=static/outfit-studio-logo.png
# Compile UNet/ControlNet with torch.compile on CUDA (default true; set false to skip compile warmup)
# OUTFIT_STUDIO_TORCH_COMPILE=true
# Persist torch.compile artifacts under .cache/torch_compile/ (speeds up restarts after first warmup)
# OUTFIT_STUDIO_TORCH_COMPILE_CACHE=true
# OUTFIT_STUDIO_TORCH_COMPILE_CACHE_DIR=.cache/torch_compile
# OUTFIT_STUDIO_INDUCTOR_CACHE_DIR=.cache/torchinductor

# --- Docker bind mounts (optional, compose only) ---
# OUTFIT_STUDIO_HOST_MODELS_DIR=./models
# OUTFIT_STUDIO_HOST_HF_CACHE=${HOME}/.cache/huggingface
