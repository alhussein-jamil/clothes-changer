# Copy to content.local.yaml for local overrides (gitignored).
#
#   cp config/content.local.yaml.example config/content.local.yaml
#
# Local YAML merges on top of config/content.default.yaml.

# app:
#   name: My Studio
#   tagline: Custom clothing editor

# prompts:
#   default: "high quality photo, detailed outfit, natural lighting"
#   negative: "worst quality, low quality, blurry, watermark"

models:
  # SD1.5 inpaint checkpoints — downloaded into models/ on first use.
  default_inpaint: cyberrealistic_v80Inpainting.safetensors

  aliases:
    realisticVisionV60B1_v51HyperInpaintVAE.safetensors:
      - realisticVisionV60B1_v51HyperInpaintVAE_full.safetensors

  download_urls:
    cyberrealistic_v80Inpainting.safetensors: >-
      https://civitai.com/api/download/models/1464918
    realisticVisionV60B1_v51HyperInpaintVAE.safetensors: >-
      https://civitai.com/api/download/models/501286
    realisticVisionV60B1_v51HyperInpaintVAE_full.safetensors: >-
      https://civitai.com/api/download/models/501286
    lazymixRealAmateur_v40Inpainting.safetensors: >-
      https://civitai.com/api/download/models/302254
    clarity_V3-inpainting.safetensors: >-
      https://civitai.com/api/download/models/145163

